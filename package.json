{
  "name": "strapi-plugin-relation-publish",
  "version": "1.0.0",
  "description": "Adds a Publish button with confirmation dialog to the relation edit modal in Strapi v5",
  "keywords": [
    "strapi",
    "strapi-plugin",
    "strapi-v5",
    "publish",
    "relation",
    "content-manager"
  ],
  "license": "MIT",
  "strapi": {
    "kind": "plugin",
    "name": "relation-publish",
    "displayName": "Relation Publish",
    "description": "Adds a Publish button to the relation edit modal in the Content Manager."
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build --minify",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify"
  },
  "devDependencies": {
    "@strapi/admin": "^5.0.0",
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "^5.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@strapi/admin": "^5.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-intl": "^6.0.0 || ^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=11.0.0"
  }
}
